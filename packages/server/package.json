    "webrtc-convergence-demo": "tsx tests/webrtc-convergence-demo.ts",
    "compact-snapshots": "tsx src/jobs/compactSnapshots.ts"
  },
  "dependencies": {
    "@collab/shared": "*",
    "argon2": "^0.41.1",
    "cors": "^2.8.5",
    "diff": "^5.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "lib0": "^0.2.94",
    "pg": "^8.12.0",
    "socket.io": "^4.7.5",
    "ws": "^8.18.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.18"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/diff": "^5.2.1",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.12",
    "node-datachannel": "^0.32.3",
    "socket.io-client": "^4.7.5",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "y-webrtc": "^10.3.0"
