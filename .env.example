# Copy this file to .env (root, for docker-compose) and/or
# packages/server/.env (for `npm run dev:server` outside Docker) and fill
# in real values. Never commit the real .env file (it's gitignored).

# --- Server -----------------------------------------------------------
NODE_ENV=development
PORT=4000

# Postgres connection string. When running via docker-compose, "postgres"
# resolves to the postgres service; when running the server locally
# against `docker compose up postgres redis`, use localhost instead.
DATABASE_URL=postgres://collab:collab@localhost:5432/collab

REDIS_URL=redis://localhost:6379

# HS256 signing secret for session JWTs. Use a long random string in any
# real deployment -- this placeholder is fine for local dev only.
JWT_SECRET=dev-secret-change-me

# Origin allowed to hit the REST API / Socket.io server (the Vite dev
# server by default).
CORS_ORIGIN=http://localhost:5173

# Debounced Postgres persistence tuning (ms) -- the server batches writes
# to Postgres instead of fsyncing on every keystroke (see README "Stack").
PERSIST_DEBOUNCE_MS=3000
PERSIST_MAX_INTERVAL_MS=30000
VERSION_CHECKPOINT_INTERVAL_MS=300000

# --- Client (Vite reads these at build/dev time, must be prefixed VITE_) --
VITE_SERVER_URL=http://localhost:4000
